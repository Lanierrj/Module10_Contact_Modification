<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Module6_Contact_Lists"
             x:DataType="vm:DetailsViewModel"
             x:Class="Module6_Contact_Lists.Details">
    <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, *" Padding="10" RowSpacing="5">
        <Entry Grid.Row="1" x:Name="ContactName"
               FontSize="Title"
               Text="{Binding Contact.Name}"
               IsReadOnly="True"/>
        <Entry Grid.Row="2" x:Name="ContactPhoneNumber"
               FontSize="Medium"
               Text="{Binding Contact.PhoneNumber}"
               IsReadOnly="True"/>
        <Entry Grid.Row="3" x:Name="ContactGmail"
               FontSize="Medium"
               Text="{Binding Contact.Email}"
               IsReadOnly="True"/>
        <Entry Grid.Row="4" x:Name="ContactDescription"
               FontSize="Subtitle"
               Text="{Binding Contact.Description}"
               IsReadOnly="True"/>
        <Button Grid.Row="5"
                Text="Edit"
                Clicked="Button_Clicked_1"/>
        <Button Grid.Row="6"
                Text="Save"
                Clicked="Button_Clicked_2"/>
        <Button Grid.Row="7"
                Text="Back"
                Clicked="Button_Clicked"/>
    </Grid>
</ContentPage>